DATABASE_URL=postgresql+psycopg2://jobuser:jobpass@localhost:5432/jobassist
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File storage — local volume (Docker mounts this as a persistent volume)
STORAGE_PATH=/app/uploads

# OpenAI (or compatible endpoint)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# AI spend control
AI_ENABLED=true
AI_MAX_REQUESTS_PER_DAY=50
AI_MAX_CV_CHARS=6000
AI_MAX_JOB_CHARS=4000

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging — "text" for local dev pretty output, "json" for production
LOG_LEVEL=INFO
LOG_FORMAT=text
