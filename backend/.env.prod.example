# Copy to .env.prod and fill in values before deploying.
# Never commit .env.prod to git.

# Provided automatically by Railway when you add a Postgres service
DATABASE_URL=postgresql://jobuser:CHANGE_ME@host:5432/jobassist

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# CORS — your Railway frontend URL
CORS_ORIGINS=https://your-frontend.up.railway.app

# File storage — Railway volume is mounted here (configure in Railway dashboard)
STORAGE_PATH=/app/uploads
